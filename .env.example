POSTGRES_PASSWORD=write_me
DATABASE_URL=postgres://write_me:write_me@db:5432/write_me?sslmode=disable
API_PORT=8080
WEB_PORT=3000
APP_ORIGIN=http://localhost:3000
API_PUBLIC_ORIGIN=http://localhost:8080
